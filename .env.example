# Plantilla segura para activacion controlada de Supabase.
# No pegar credenciales reales en chats ni commitear .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mantener en false hasta que tabla, Storage, RLS/policies y fallback esten
# validados en un entorno controlado.
NEXT_PUBLIC_CE_SUPABASE_ENABLED=false
